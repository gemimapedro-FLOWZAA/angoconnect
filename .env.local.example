# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Price IDs por plano — criar no Stripe Dashboard (Products → Prices)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Resend (outreach motor — M2.3)
# RESEND_FROM_EMAIL precisa de domínio verificado no Resend dashboard.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@angoconnect.app
RESEND_FROM_NAME=AngoConnect
# Reply-To opcional — se vazio, replies vão para o RESEND_FROM_EMAIL.
RESEND_REPLY_TO=
# Webhook secret (formato `whsec_<base64>`) — obter em Resend → Webhooks.
# Em dev podes deixar vazio (webhook aceita sem verificação + warn).
RESEND_WEBHOOK_SECRET=

# Apify
APIFY_TOKEN=
APIFY_WEBHOOK_SECRET=

# Redis (BullMQ — outreach motor)
REDIS_URL=

# Cron secret (Vercel Cron Authorization: Bearer ${CRON_SECRET})
# Gera com: openssl rand -hex 32
CRON_SECRET=

# Worker (opcional — só relevante para `npm run worker` em self-host)
WORKER_CONCURRENCY=5

# Claude (copy generation)
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (error tracking — opcional em dev, obrigatório em produção)
# DSN do projecto em https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
# Apenas em CI: necessário para upload de sourcemaps no build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Playwright E2E — só usado pelos testes em e2e/
# AVISO: SERVICE KEY = admin total. Apontar sempre para Supabase local.
E2E_SUPABASE_URL=http://127.0.0.1:54321
E2E_SUPABASE_SERVICE_KEY=
E2E_BASE_URL=http://localhost:3000
