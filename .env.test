# AngoConnect — Variáveis de ambiente usadas pela suite de testes.
# Todas são placeholders inócuos. Os testes mockam clients reais (Supabase,
# Resend, Stripe, Anthropic) — só precisamos das vars para que os módulos
# que lêem env no top-level não rebentem no import.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=test-anon
SUPABASE_SERVICE_ROLE_KEY=test-service

# Stripe
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
STRIPE_PRICE_STARTER=price_starter_test
STRIPE_PRICE_GROWTH=price_growth_test
STRIPE_PRICE_PRO=price_pro_test

# Resend
RESEND_API_KEY=re_dummy
RESEND_FROM_EMAIL=test@example.com
RESEND_FROM_NAME=AngoConnect Test

# Anthropic
ANTHROPIC_API_KEY=sk-ant-dummy

# Apify
APIFY_TOKEN=apify_dummy
APIFY_WEBHOOK_SECRET=apify-secret
APIFY_ACTOR_IRGC=user~irgc-scraper
APIFY_ACTOR_LINKEDIN=user~linkedin-scraper
APIFY_ACTOR_EMAIL_ENRICHER=user~email-enricher

# BullMQ / Redis
REDIS_URL=redis://localhost:6379

# Cron / Meta / App
CRON_SECRET=cron-secret
META_APP_SECRET=meta-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
